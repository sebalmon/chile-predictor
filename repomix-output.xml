        <p style={{ fontFamily:"'Press Start 2P',monospace", fontSize:"6px",
          color: msgRec.startsWith("✅") ? "var(--verde-claro)" : "var(--rojo-chile)",
          textAlign:"center", marginBottom:"10px", lineHeight:2 }}>{msgRec}</p>
      )}
