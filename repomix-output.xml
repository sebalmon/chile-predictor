        <div style={{ textAlign: "center" }}>
          <div style={{ fontSize: "36px", marginBottom: "8px" }}>{pasoActual.icono}</div>
          <h2 style={{ color: pasoActual.color, fontSize: "11px" }}>{pasoActual.titulo}</h2>
