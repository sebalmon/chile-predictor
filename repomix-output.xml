  font-size: 14px;
  width: 48px;
  height: 48px;
  text-align: center;
  border: 3px solid var(--negro);
  background: var(--blanco);
  color: var(--negro);
  outline: none;
}

.resultado-exacto input:focus {
  border-color: var(--amarillo);
}

.pred-guardado-ok {
  font-size: 7px;
  color: var(--verde-claro);
