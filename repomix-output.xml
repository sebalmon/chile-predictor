/* ============================================================
   CHILE PREDICTOR 8-BIT — ESTILOS GLOBALES
   Fuente: Press Start 2P (Google Fonts)
   Paleta: Verde cancha + rojo Chile + pixel art
   ============================================================ */

:root {
  --verde-oscuro: #1a472a;
  --verde-medio: #2d6a4f;
  --verde-claro: #52b788;
  --verde-campo: #40916c;
  --rojo-chile: #d62828;
  --rojo-oscuro: #9b1c1c;
  --amarillo: #f4d03f;
  --amarillo-oscuro: #d4ac0d;
  --blanco: #f5f5f0;
  --negro: #1a1a1a;
  --gris: #555555;
  --gris-claro: #cccccc;
  --azul: #2563eb;
  --pixel-border: 3px solid var(--negro);
  --sombra-pixel: 4px 4px 0px var(--negro);
  --sombra-pixel-rojo: 4px 4px 0px var(--rojo-oscuro);
  --sombra-pixel-verde: 4px 4px 0px var(--verde-oscuro);
}

*, *::before, *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html, body {
  height: 100%;
  overflow-x: hidden;
}

body {
  font-family: "Press Start 2P", monospace;
  background-color: var(--verde-oscuro);
  background-image:
    linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px);
  background-size: 20px 20px;
  color: var(--blanco);
  min-height: 100vh;
  font-size: 10px;
  line-height: 1.8;
}

#root {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* ── SCROLLBAR PIXELADA ── */
::-webkit-scrollbar { width: 8px; }
::-webkit-scrollbar-track { background: var(--verde-oscuro); }
::-webkit-scrollbar-thumb {
  background: var(--verde-claro);
  border: 2px solid var(--negro);
}

/* ── BOTONES PIXEL ── */
.btn-pixel {
  font-family: "Press Start 2P", monospace;
  font-size: 9px;
  padding: 10px 16px;
  border: 3px solid var(--negro);
  cursor: pointer;
  display: inline-block;
  transition: transform 0.05s, box-shadow 0.05s;
  text-transform: uppercase;
  letter-spacing: 1px;
  user-select: none;
  text-align: center;
}

.btn-pixel:active {
  transform: translate(3px, 3px);
  box-shadow: none !important;
}

.btn-verde {
  background: var(--verde-claro);
  color: var(--negro);
  box-shadow: var(--sombra-pixel-verde);
}
.btn-verde:hover { background: #74c69d; }

.btn-rojo {
  background: var(--rojo-chile);
  color: var(--blanco);
  box-shadow: var(--sombra-pixel-rojo);
}
.btn-rojo:hover { background: #e74c3c; }

.btn-amarillo {
  background: var(--amarillo);
  color: var(--negro);
  box-shadow: 4px 4px 0px var(--amarillo-oscuro);
}
.btn-amarillo:hover { background: #f7dc6f; }

.btn-gris {
  background: var(--gris);
  color: var(--blanco);
  box-shadow: 4px 4px 0px #333;
}
.btn-gris:hover { background: #777; }

.btn-pixel:disabled {
  opacity: 0.4;
  cursor: not-allowed;
  transform: none !important;
  box-shadow: var(--sombra-pixel) !important;
}

/* ── CAJAS PIXEL ── */
.caja-pixel {
  background: var(--verde-medio);
  border: 3px solid var(--negro);
  box-shadow: var(--sombra-pixel);
  padding: 16px;
}

.caja-blanca {
  background: var(--blanco);
  color: var(--negro);
  border: 3px solid var(--negro);
  box-shadow: var(--sombra-pixel);
  padding: 16px;
}

/* ── INPUTS PIXEL ── */
.input-pixel {
  font-family: "Press Start 2P", monospace;
  font-size: 9px;
  padding: 10px 12px;
  border: 3px solid var(--negro);
  background: var(--blanco);
  color: var(--negro);
  width: 100%;
  outline: none;
  box-shadow: inset 2px 2px 0px rgba(0,0,0,0.2);
}

.input-pixel:focus {
  border-color: var(--verde-claro);
  box-shadow: inset 2px 2px 0px rgba(0,0,0,0.2), 0 0 0 2px var(--verde-claro);
}

/* ── TÍTULOS ── */
h1 {
  font-size: 18px;
  text-shadow: 3px 3px 0px var(--negro);
  letter-spacing: 2px;
}
h2 { font-size: 13px; text-shadow: 2px 2px 0px var(--negro); }
h3 { font-size: 10px; }

/* ── LAYOUT ── */
.pantalla {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20px;
}

.contenedor {
  width: 100%;
  max-width: 640px;
  margin: 0 auto;
  padding: 0 16px;
}

/* ── BARRA SUPERIOR ── */
.topbar {
  background: var(--negro);
  border-bottom: 3px solid var(--verde-claro);
  padding: 10px 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  z-index: 100;
}

.topbar-logo {
  font-size: 8px;
  color: var(--verde-claro);
  text-shadow: 2px 2px 0 var(--verde-oscuro);
}

/* ── AVATAR EN TOPBAR ── */
.avatar-topbar {
