  background: none;
  border: none;
  font-family: "Press Start 2P", monospace;
}

.menu-item.activo, .menu-item:hover {
  color: var(--amarillo);
}

.menu-item-icono { font-size: 18px; }

/* ── SECCIÓN DASHBOARD ── */
.dashboard-wrapper {
  padding-bottom: 80px; /* espacio para menú inferior */
  padding-top: 16px;
}

.seccion-titulo {
  font-size: 9px;
  color: var(--amarillo);
  text-shadow: 2px 2px 0 var(--negro);
  margin-bottom: 12px;
  padding-bottom: 6px;
  border-bottom: 2px solid var(--verde-campo);
  display: flex;
  align-items: center;
  gap: 8px;
}

/* ── PODIO ── */
.podio {
  display: flex;
  justify-content: center;
  align-items: flex-end;
  gap: 8px;
  margin-bottom: 8px;
}

.podio-lugar {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}

.podio-bloque {
  border: 3px solid var(--negro);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 8px;
  color: var(--negro);
  font-weight: bold;
  width: 60px;
}

.podio-1 .podio-bloque { height: 64px; background: var(--amarillo); box-shadow: var(--sombra-pixel); }
.podio-2 .podio-bloque { height: 48px; background: var(--gris-claro); box-shadow: var(--sombra-pixel); }
.podio-3 .podio-bloque { height: 36px; background: #cd7f32; box-shadow: var(--sombra-pixel); }

.podio-nickname { font-size: 6px; text-align: center; max-width: 70px; color: var(--blanco); }
.podio-puntos { font-size: 7px; color: var(--verde-claro); }
.podio-avatar { font-size: 20px; }

/* ── RANKING TABLE ── */
.ranking-tabla {
  width: 100%;
  border-collapse: collapse;
}

.ranking-tabla th, .ranking-tabla td {
  padding: 8px 6px;
  font-size: 7px;
  border-bottom: 1px solid var(--verde-campo);
  text-align: left;
}

.ranking-tabla th {
  color: var(--amarillo);
  font-size: 6px;
  border-bottom: 2px solid var(--verde-campo);
}

.ranking-fila-yo {
  background: rgba(82, 183, 136, 0.2);
  border-left: 3px solid var(--verde-claro) !important;
}

.ranking-pos {
