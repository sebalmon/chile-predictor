                    <div style={{ display: "flex", alignItems: "center", gap: "8px" }}>
                      <span style={{ fontSize: "16px" }}>{u.avatarEmoji}</span>
                      <div>
                        <div style={{ fontSize: "7px", color: "var(--blanco)" }}>
                          {u.nickname}
