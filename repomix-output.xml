  text-shadow: 2px 2px 0px rgba(0,0,0,0.3);
  white-space: nowrap;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0; }
}

/* Ajuste del texto inferior para que no se corte */
.splash-texto-final {
  position: absolute;
  bottom: 15%;          /* subir un poco */
  left: 0;
  right: 0;
  text-align: center;
  font-family: 'Press Start 2P', monospace;
  font-size: 8px;
  background: linear-gradient(45deg, #ffcc00, #ff6600);
