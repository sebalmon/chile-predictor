                    {opcionesNv.length < 5 && (
                      <button
                        className="btn-pixel btn-gris w-full"
                        style={{ fontSize:"5px", marginBottom:"10px" }}
                        onClick={() => setOpcionesNv(prev => [...prev, ""])}>
                        + AGREGAR OPCIÓN
                      </button>
                    )}

                    {/* Puntaje variable */}
                    <p style={{ fontSize:"5px", color:"var(--gris-claro)", marginBottom:"5px" }}>
                      PUNTAJE POR ACERTAR:
