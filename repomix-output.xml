/* ── RESPONSIVE ── */
@media (max-width: 480px) {
  h1 { font-size: 13px; }
  h2 { font-size: 10px; }
  .podio-bloque { width: 50px; }
  .pred-opciones { flex-direction: column; }
  .pregunta-opciones { grid-template-columns: 1fr; }
  .cartas-grid { grid-template-columns: repeat(2, 1fr); }
  .avatar-grid { grid-template-columns: repeat(4, 1fr); }
}

.splash-container {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background: black;
}

.splash-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.fade-in {
  animation: fadeIn 0.5s ease-in forwards;
}
.slide-in-right {
  animation: slideInFromRight 0.5s ease-out forwards;
}
.static {
  opacity: 1;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideInFromRight {
  from { transform: translateX(100%); opacity: 0; }
  to { transform: translateX(0); opacity: 1; }
}

.splash {
  position: relative;
  width: 100vw;
  height: 100vh;
  background: black;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.texto-splash {
  text-align: center;
  font-family: 'Press Start 2P', monospace;
  font-size: 8px;
  background: linear-gradient(45deg, #ffa500, #ffd700);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  margin-top: 20px;
}

/* === CONTENEDOR PRINCIPAL DEL SPLASH === */
.splash-container-unificado {
  position: relative;
  width: 100vw;
  height: 100vh; 
  overflow: hidden;
  background-color: rgb(225, 225, 225); /* fondo de seguridad mientras cargan imágenes */
}

/* TODAS las imágenes ocupan toda la pantalla */
.splash-fondo {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover; /* para que cubra sin deformarse */
  display: block;
}

/* Animaciones */
.fade-in {
  animation: fadeIn 0.5s ease-in forwards;
}
.slide-in-right {
  animation: slideInFromRight 0.5s ease-out forwards;
}
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
@keyframes slideInFromRight {
  from { transform: translateX(100%); opacity: 0; }
  to { transform: translateX(0); opacity: 1; }
}

/* Texto final – centrado abajo, SOBRE la imagen */
.splash-texto-final {
  position: absolute;
  bottom: 15%;           /* ← antes era 30px o 50px; ahora usa porcentaje */
  left: 0;
  right: 0;
  text-align: center;
  font-family: 'Press Start 2P', monospace;
  font-size: 8px;
  background: linear-gradient(45deg, #ffcc00, #ff6600);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  z-index: 20;
  line-height: 1.6;
  pointer-events: none;
  padding: 0 15px;       /* ← añade esto para que no toque los bordes laterales */
}

/* Texto START centrado, parpadeante */
.splash-start {
  position: absolute;
  top: 43%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-family: 'Press Start 2P', monospace;
  font-size: 24px;       /* más grande */
  font-weight: bold;
  background: linear-gradient(45deg, #ffcc00, #ff6600);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  text-align: center;
  z-index: 30;
  animation: blink 1s step-end infinite;
  text-shadow: 2px 2px 0px rgba(0,0,0,0.3);
  white-space: nowrap;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0; }
}

/* Ajuste del texto inferior para que no se corte */
.splash-texto-final {
  position: absolute;
  bottom: 15%;          /* subir un poco */
  left: 0;
  right: 0;
  text-align: center;
  font-family: 'Press Start 2P', monospace;
  font-size: 8px;
  background: linear-gradient(45deg, #ffcc00, #ff6600);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  z-index: 20;
  line-height: 1.6;
  pointer-events: none;
  padding: 0 15px;
}

/* ── PODIO ESTILO FÓRMULA 1 ── */
.podio-f1-container {
  display: flex;
  justify-content: center;
  align-items: flex-end;
  gap: 6px;
  margin: 20px 0;
  padding-bottom: 10px;
  border-bottom: 4px dashed var(--gris);
}

.podio-escalon {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  max-width: 110px;
}

.podio-avatares-cluster {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 4px;
  margin-bottom: 8px;
  min-height: 52px;
}

.podio-jugador-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.podio-jugador-name {
  font-size: 5px;
  color: var(--blanco);
  background: var(--negro);
  padding: 2px;
  border: 1px solid var(--gris);
  margin-top: 2px;
  max-width: 50px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.podio-bloque-fisico {
  width: 100%;
  border: 4px solid var(--negro);
  border-bottom: none;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-family: 'Press Start 2P', monospace;
  box-shadow: inset -4px -4px 0px rgba(0,0,0,0.2);
}

.podio-bloque-numero {
  font-size: 14px;
  font-weight: bold;
  color: var(--negro);
}

/* ── ANIMACIÓN INDIVIDUAL DE 3 FOTOGRAMAS POR AVATAR ── */
.avatar-pixel-animado {
  width: 42px;
  height: 42px;
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
  image-rendering: pixelated;
  cursor: pointer;
}

.avatar-pixel-animado.pequeno {
  width: 24px;
  height: 24px;
}

