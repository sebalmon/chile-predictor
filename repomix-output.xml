          <div className="loading-pantalla" style={{ minHeight:"200px" }}>
            <span className="spinner">⚙</span><p>CARGANDO...</p>
          </div>
        ) : (
          <>
            {/* PODIO F1 */}
            <div className="seccion-titulo">🏆 PODIO DEL DÍA ANTERIOR</div>
