                <span style={{ color: "var(--gris-claro)" }}>{r.desc}</span>
                <span style={{ color: "var(--amarillo)" }}>{r.pts}</span>
              </div>
            ))}
          </div>

          <p style={{ fontSize: "6px", color: "var(--verde-claro)", marginTop: "12px", lineHeight: 2 }}>
