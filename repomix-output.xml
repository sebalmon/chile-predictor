}

function TopBar({ userProfile, onPerfil, onLogout, diaLabel }) {
  return (
    <div className="topbar">
      <span className="topbar-logo"
        style={{ color:"var(--amarillo)", fontSize:"8px" }}>
        ⚽ {diaLabel}
