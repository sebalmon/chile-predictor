  padding: 2px 4px;
  background: var(--negro);
  line-height: 1;
}

.avatar-tooltip {
  display: none;
  position: absolute;
  top: 110%;
  right: 0;
  background: var(--negro);
  color: var(--verde-claro);
  border: 2px solid var(--verde-claro);
  padding: 6px 10px;
  font-size: 7px;
  white-space: nowrap;
  z-index: 200;
  box-shadow: var(--sombra-pixel-verde);
}

.avatar-topbar:hover .avatar-tooltip {
  display: block;
}

.nickname-topbar {
  font-size: 8px;
  color: var(--amarillo);
  max-width: 120px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ── MENÚ INFERIOR ── */
.menu-inferior {
