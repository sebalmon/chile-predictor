          {cargando ? "CONECTANDO..." : "ENTRAR CON GOOGLE"}
        </button>

        <p style={{ fontSize: "6px", color: "var(--gris)", textAlign: "center" }}>
          ⚠ Solo para invitados del grupo
        </p>
      </div>
    </div>
  );
}
