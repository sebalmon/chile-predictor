rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── usuarios ───────────────────────────────────────────
    match /usuarios/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null;
    }

    // ── predicciones ──────────────────────────────────────
    match /predicciones/{docId} {
      allow read, write: if request.auth != null;
    }

    // ── respuestas (pregunta del día) ──────────────────────
    match /respuestas/{docId} {
      allow read, write: if request.auth != null;
    }

    // ── partidos ──────────────────────────────────────────
    match /partidos/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── preguntas ─────────────────────────────────────────
    match /preguntas/{docId} {
      allow read, write: if request.auth != null;
    }

    // ── puntosDelDia ──────────────────────────────────────
    match /puntosDelDia/{docId} {
      allow read, write: if request.auth != null;
    }

    // ── cartasDelUsuario ──────────────────────────────────
    match /cartasDelUsuario/{docId} {
      allow read, write: if request.auth != null;
    }

    // ── sobresDelDia ──────────────────────────────────────
    match /sobresDelDia/{docId} {
      allow read, write: if request.auth != null;
    }

    // ── config ────────────────────────────────────────────
    match /config/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── mensajesDia ───────────────────────────────────────
    match /mensajesDia/{docId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // ── Reacciones a mensajes (subcolección) ──────────────
    match /mensajesDia/{docId}/reacciones/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── admins ────────────────────────────────────────────
    match /admins/{uid} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── NUEVO: Preguntas en vivo (Super Destacado) ────────
    match /preguntasEnVivo/{partidoId}/preguntas/{pregId} {
      allow read: if request.auth != null;
      // Solo admin puede crear/modificar preguntas en vivo
      allow write: if request.auth != null;
    }

    match /preguntasEnVivo/{partidoId}/respuestasEnVivo/{respId} {
      allow read: if request.auth != null;
      // Usuarios pueden crear su propia respuesta (una vez)
      allow create: if request.auth != null &&
        respId.matches(request.auth.uid + '_.*');
      // No se puede editar una respuesta ya enviada
      allow update, delete: if false;
    }

    // ── NUEVO: Carta diaria ────────────────────────────────
    match /cartaDiaria/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── NUEVO: Notificaciones de usuario ──────────────────
    match /usuarios/{uid}/notificaciones/{nId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
