rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ── Helpers ────────────────────────────────────────────────
    function esAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ── usuarios ───────────────────────────────────────────────
    match /usuarios/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null;
      
      match /notificaciones/{notifId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ── predicciones ───────────────────────────────────────────
    match /predicciones/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── respuestas ─────────────────────────────────────────────
    match /respuestas/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── partidos ───────────────────────────────────────────────
    match /partidos/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── preguntas ──────────────────────────────────────────────
    match /preguntas/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── puntosDelDia ───────────────────────────────────────────
    match /puntosDelDia/{docId} {
      allow read, write: if request.auth != null;
    }

    // ── cartasDelUsuario ───────────────────────────────────────
    match /cartasDelUsuario/{docId} {
      allow read, write: if request.auth != null;
    }

    // ── config ──────────────────────────────────────────────────
    match /config/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── mensajesDia ────────────────────────────────────────────
    match /mensajesDia/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // ── Reacciones en mensajes ────────────────────────────────
    match /mensajesDia/{docId}/reacciones/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── admins ──────────────────────────────────────────────────
    match /admins/{uid} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── sobresDelDia ───────────────────────────────────────────
    match /sobresDelDia/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── NUEVO: preguntasEnVivo (Super Destacado) ───────────────
    // El admin crea preguntas; los usuarios las leen y responden.
    match /preguntasEnVivo/{partidoId}/preguntas/{pregId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /preguntasEnVivo/{partidoId}/respuestasEnVivo/{respId} {
      allow read: if request.auth != null;
      // Cada usuario solo puede crear/leer su propia respuesta
      allow create: if request.auth != null;
      allow update: if false; // No se puede cambiar una respuesta ya enviada
      allow delete: if false;
    }

  }
}
