rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function esAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /usuarios/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null;
      match /notificaciones/{notifId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    match /predicciones/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /respuestas/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /partidos/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /preguntas/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /puntosDelDia/{docId} {
      allow read, write: if request.auth != null;
    }

    match /cartasDelUsuario/{docId} {
      allow read, write: if request.auth != null;
    }

    match /config/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /mensajesDia/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /mensajesDia/{docId}/reacciones/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    match /admins/{uid} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /sobresDelDia/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /preguntasEnVivo/{partidoId}/preguntas/{pregId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /preguntasEnVivo/{partidoId}/respuestasEnVivo/{respId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if false;
      allow delete: if false;
    }

    match /pronosticoCuartos/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /pronosticoCuartos_votos/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /semifinales/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /semifinales_votos/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /eventoEnVivo/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /eventoEnVivo/{docId}/respuestas/{respId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }

  }
}
