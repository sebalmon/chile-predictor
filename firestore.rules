// ============================================================
// REGLAS DE SEGURIDAD FIRESTORE
// Pégalas en: Firebase Console > Firestore > Reglas
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Usuarios ────────────────────────────────────────────
    // Cualquier usuario autenticado puede leer perfiles (para ranking)
    // Solo el propio usuario puede escribir su perfil
    match /usuarios/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false; // nadie puede borrar perfiles
    }

    // ── Predicciones ────────────────────────────────────────
    // El ID del documento es: uid_partidoId
    // Solo el propio usuario puede leer y escribir sus predicciones
    match /predicciones/{docId} {
      allow read: if request.auth != null &&
        resource.data.uid == request.auth.uid;
      allow write: if request.auth != null &&
        request.resource.data.uid == request.auth.uid;
    }

    // ── Respuestas a preguntas ───────────────────────────────
    // El ID del documento es: uid_preguntaId
    match /respuestas/{docId} {
      allow read: if request.auth != null &&
        resource.data.uid == request.auth.uid;
      allow write: if request.auth != null &&
        request.resource.data.uid == request.auth.uid;
    }

    // ── Partidos (solo lectura para usuarios) ────────────────
    // Solo admin (tú) puede escribir desde Firebase Console
    match /partidos/{docId} {
      allow read: if request.auth != null;
      allow write: if false; // solo desde Firebase Console
    }

    // ── Preguntas del día (solo lectura) ─────────────────────
    match /preguntas/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Puntos del día (para podio) ──────────────────────────
    match /puntosDelDia/{docId} {
      allow read: if request.auth != null;
      allow write: if false; // solo admin
    }
  }
}
