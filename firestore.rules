rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────
    function esAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ── usuarios ───────────────────────────────────────────────
    // Cualquier usuario autenticado puede leer perfiles (para ranking/podio).
    // Solo el propio usuario puede crear su documento.
    // Update permitido a cualquier autenticado: el sistema del admin
    //   necesita updateDoc en usuarios ajenos para sumar puntosTotal.
    //   La lógica de negocio que impide abusos vive en el código.
    match /usuarios/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null;
    }

    // ── predicciones ───────────────────────────────────────────
    // El admin procesa predicciones ajenas (añade puntosGanados, etc.)
    match /predicciones/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── respuestas (pregunta del día) ───────────────────────────
    match /respuestas/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── partidos ───────────────────────────────────────────────
    match /partidos/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── preguntas ──────────────────────────────────────────────
    match /preguntas/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── puntosDelDia ───────────────────────────────────────────
    match /puntosDelDia/{docId} {
      allow read, write: if request.auth != null;
    }

    // ── cartasDelUsuario ───────────────────────────────────────
    match /cartasDelUsuario/{docId} {
      allow read, write: if request.auth != null;
    }

    // ── config (avisos del admin) ───────────────────────────────
    match /config/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── mensajesDia (La Voz de la Hinchada) ────────────────────
    match /mensajesDia/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // ── admins ─────────────────────────────────────────────────
    match /admins/{uid} {
      allow read: if request.auth != null;
      allow write: if false; // solo desde Firebase Console
    }
  }
}
